<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>🌍 世界の株式市場ダッシュボード</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700;900&family=Inter:wght@400;700;900&display=swap" rel="stylesheet" />
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg0: #0a0a1a; --bg1: #11112a; --bg2: #1a1a3a;
      --glass: rgba(255,255,255,.06); --glass-b: rgba(255,255,255,.12);
      --up: #00ffa3; --down: #ff4d6d; --flat: #aaaacc;
      --accent1: #7c3aed; --accent2: #ec4899; --accent3: #06b6d4;
      --text: #e2e8f0; --muted: #94a3b8; --radius: 14px;
    }
    html { scroll-behavior: smooth; }
    body { font-family:'Noto Sans JP','Inter',sans-serif; background:var(--bg0); color:var(--text); min-height:100vh; overflow-x:hidden; }
    body::before {
      content:""; position:fixed; inset:0; z-index:-1;
      background: radial-gradient(ellipse 80% 50% at 20% -10%, rgba(124,58,237,.35) 0%,transparent 60%),
                  radial-gradient(ellipse 60% 40% at 80% 110%, rgba(6,182,212,.25) 0%,transparent 55%),
                  radial-gradient(ellipse 50% 60% at 50% 50%,  rgba(236,72,153,.12) 0%,transparent 70%);
      animation: bgPulse 12s ease-in-out infinite alternate;
    }
    @keyframes bgPulse { 0%{opacity:.8} 100%{opacity:1} }
    .up{color:var(--up)} .down{color:var(--down)} .flat{color:var(--flat)}
    .glass { background:var(--glass); border:1px solid var(--glass-b); backdrop-filter:blur(12px); border-radius:var(--radius); }

    /* ── ヘッダー ── */
    header { text-align:center; padding:2rem 1rem 1rem; }
    .site-title {
      font-size:clamp(1.6rem,5vw,3rem); font-weight:900;
      background:linear-gradient(135deg,#a78bfa,#ec4899,#06b6d4);
      -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
      animation:titleGlow 4s ease-in-out infinite alternate;
    }
    @keyframes titleGlow {
      from{filter:drop-shadow(0 0 20px rgba(167,139,250,.4))}
      to  {filter:drop-shadow(0 0 40px rgba(236,72,153,.5))}
    }
    .update-badge {
      display:inline-flex; align-items:center; gap:.4rem; margin-top:.6rem;
      padding:.3rem .9rem; background:rgba(6,182,212,.15); border:1px solid rgba(6,182,212,.3);
      border-radius:999px; font-size:.78rem; color:var(--accent3);
    }
    .pulse-dot { width:7px; height:7px; border-radius:50%; background:var(--accent3); animation:pulse 1.5s ease-in-out infinite; }
    @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(1.5)} }

    /* ── ティッカーバー ── */
    .ticker-wrap { overflow:hidden; background:rgba(255,255,255,.04); border-top:1px solid rgba(255,255,255,.08); border-bottom:1px solid rgba(255,255,255,.08); padding:.5rem 0; white-space:nowrap; }
    .ticker-track { display:inline-flex; gap:2rem; animation:tickerScroll 50s linear infinite; }
    .ticker-wrap:hover .ticker-track { animation-play-state:paused; }
    @keyframes tickerScroll { from{transform:translateX(0)} to{transform:translateX(-50%)} }
    .ticker-item { display:inline-flex; align-items:center; gap:.35rem; font-size:.82rem; font-weight:700; }

    /* ── セクション共通 ── */
    .section { padding:1.2rem 1rem; max-width:1400px; margin:0 auto; }
    .section-title { font-size:1.1rem; font-weight:700; margin-bottom:.8rem; display:flex; align-items:center; gap:.5rem; }
    .divider { height:1px; background:linear-gradient(90deg,transparent,rgba(167,139,250,.3),transparent); margin:.25rem 0; max-width:1400px; margin-left:auto; margin-right:auto; }

    /* ── 市場タイマー ── */
    .timer-bar {
      max-width:1400px; margin:0 auto; padding:.7rem 1rem;
      display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:.5rem;
      background:rgba(255,255,255,.04); border-bottom:1px solid rgba(255,255,255,.08);
    }
    .timer-clock { font-size:1.5rem; font-weight:900; font-variant-numeric:tabular-nums; letter-spacing:.05em; }
    .market-status { display:flex; align-items:center; gap:.6rem; flex-wrap:wrap; }
    .status-badge {
      padding:.3rem .9rem; border-radius:999px; font-size:.78rem; font-weight:700;
      display:inline-flex; align-items:center; gap:.35rem;
    }
    .status-open    { background:rgba(0,255,163,.15); border:1px solid rgba(0,255,163,.4); color:var(--up); }
    .status-closed  { background:rgba(170,170,204,.1); border:1px solid rgba(170,170,204,.25); color:var(--flat); }
    .status-pre     { background:rgba(251,191,36,.12); border:1px solid rgba(251,191,36,.3); color:#fbbf24; }
    .status-lunch   { background:rgba(6,182,212,.12);  border:1px solid rgba(6,182,212,.3);  color:var(--accent3); }
    .countdown { font-size:.82rem; color:var(--muted); }

    /* ── 寄り付き前チェック ── */
    .premarket-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:.75rem; }
    @media(max-width:600px){ .premarket-grid{ grid-template-columns:1fr 1fr; } }
    .premarket-card {
      padding:.85rem 1rem; border-radius:var(--radius); text-align:center;
      background:linear-gradient(135deg,rgba(251,191,36,.1),rgba(245,158,11,.06));
      border:1px solid rgba(251,191,36,.25); transition:transform .2s;
    }
    .premarket-card:hover { transform:translateY(-3px); }
    .premarket-card .pm-emoji { font-size:1.4rem; }
    .premarket-card .pm-name  { font-size:.7rem; color:var(--muted); margin:.2rem 0; }
    .premarket-card .pm-price { font-size:1rem; font-weight:700; }
    .premarket-card .pm-pct   { font-size:.8rem; font-weight:700; margin-top:.15rem; }

    /* ── コンパクト価格行（指数・コモディティ・仮想通貨）── */
    .compact-row { display:flex; flex-wrap:wrap; gap:.5rem; }
    .compact-chip {
      display:inline-flex; align-items:center; gap:.4rem;
      padding:.45rem .85rem; border-radius:999px;
      background:var(--glass); border:1px solid var(--glass-b);
      font-size:.82rem; font-weight:700; transition:transform .15s;
      white-space:nowrap;
    }
    .compact-chip:hover { transform:scale(1.04); }
    .compact-chip .chip-name  { color:var(--muted); font-size:.75rem; }
    .compact-chip .chip-price { }
    .compact-chip .chip-pct   { font-size:.75rem; }

    /* ── 為替感応度マップ ── */
    .fx-map { display:grid; grid-template-columns:1fr 1fr; gap:.75rem; }
    @media(max-width:500px){ .fx-map{ grid-template-columns:1fr; } }
    .fx-card {
      padding:1rem; border-radius:var(--radius);
    }
    .fx-card.weak-yen  { background:rgba(0,255,163,.07);  border:1px solid rgba(0,255,163,.2); }
    .fx-card.strong-yen{ background:rgba(255,77,109,.07); border:1px solid rgba(255,77,109,.2); }
    .fx-card-title { font-size:.82rem; font-weight:700; margin-bottom:.6rem; display:flex; align-items:center; gap:.4rem; }
    .fx-tag {
      display:inline-block; padding:.2rem .6rem; border-radius:999px;
      font-size:.72rem; font-weight:700; margin:.2rem .2rem .2rem 0;
    }
    .fx-up   { background:rgba(0,255,163,.15);  color:var(--up);   border:1px solid rgba(0,255,163,.3);  }
    .fx-down { background:rgba(255,77,109,.15); color:var(--down); border:1px solid rgba(255,77,109,.3); }
    .fx-indicator {
      display:flex; align-items:center; gap:.6rem; margin-bottom:.75rem;
      padding:.5rem .85rem; border-radius:999px; font-size:.85rem; font-weight:700;
      width:fit-content;
    }
    .fx-indicator.up   { background:rgba(0,255,163,.12); border:1px solid rgba(0,255,163,.3); color:var(--up); }
    .fx-indicator.down { background:rgba(255,77,109,.12); border:1px solid rgba(255,77,109,.3); color:var(--down); }
    .fx-indicator.flat { background:rgba(170,170,204,.08); border:1px solid rgba(170,170,204,.2); color:var(--flat); }

    /* ── セクターピル ── */
    .sector-grid { display:flex; flex-wrap:wrap; gap:.5rem; }
    .sector-pill {
      display:flex; align-items:center; gap:.35rem; padding:.42rem .85rem;
      border-radius:999px; font-size:.8rem; font-weight:700; transition:transform .15s; cursor:default;
    }
    .sector-pill:hover { transform:scale(1.06); }
    .sector-pill.up   { background:rgba(0,255,163,.12);   border:1px solid rgba(0,255,163,.3);   color:var(--up); }
    .sector-pill.down { background:rgba(255,77,109,.12);  border:1px solid rgba(255,77,109,.3);  color:var(--down); }
    .sector-pill.flat { background:rgba(170,170,204,.08); border:1px solid rgba(170,170,204,.2); color:var(--flat); }

    /* ── 値上がり・値下がりランキング ── */
    .ranking-grid { display:grid; grid-template-columns:1fr 1fr; gap:.75rem; }
    @media(max-width:500px){ .ranking-grid{ grid-template-columns:1fr; } }
    .ranking-list { border-radius:var(--radius); overflow:hidden; }
    .ranking-header {
      padding:.6rem 1rem; font-size:.82rem; font-weight:700;
      display:flex; align-items:center; gap:.4rem;
    }
    .ranking-header.up-head   { background:rgba(0,255,163,.12);  border:1px solid rgba(0,255,163,.25);  color:var(--up);   border-bottom:none; border-radius:var(--radius) var(--radius) 0 0; }
    .ranking-header.down-head { background:rgba(255,77,109,.12); border:1px solid rgba(255,77,109,.25); color:var(--down); border-bottom:none; border-radius:var(--radius) var(--radius) 0 0; }
    .ranking-body.up-body   { border:1px solid rgba(0,255,163,.2);  border-top:none; border-radius:0 0 var(--radius) var(--radius); background:rgba(0,255,163,.03); }
    .ranking-body.down-body { border:1px solid rgba(255,77,109,.2); border-top:none; border-radius:0 0 var(--radius) var(--radius); background:rgba(255,77,109,.03); }
    .ranking-row {
      display:flex; align-items:center; justify-content:space-between;
      padding:.55rem 1rem; border-bottom:1px solid rgba(255,255,255,.05); font-size:.85rem;
    }
    .ranking-row:last-child { border-bottom:none; }
    .rank-num { font-size:.7rem; color:var(--muted); width:1.2rem; flex-shrink:0; }
    .rank-name { flex:1; font-weight:700; }
    .rank-pct  { font-weight:700; font-size:.88rem; }

    /* ── ウォッチリスト ── */
    .watchlist-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:1rem; }
    .watch-card {
      border-radius:var(--radius); overflow:hidden;
      background:var(--glass); border:1px solid rgba(255,255,255,.1);
      transition:transform .2s, box-shadow .2s;
    }
    .watch-card:hover { transform:translateY(-4px); box-shadow:0 10px 35px rgba(0,0,0,.4); }
    .watch-header {
      padding:.85rem 1rem; display:flex; align-items:center; gap:.75rem;
      background:rgba(255,255,255,.04); border-bottom:1px solid rgba(255,255,255,.07);
    }
    .watch-emoji { font-size:2rem; flex-shrink:0; }
    .watch-info  { flex:1; }
    .watch-name  { font-size:1rem; font-weight:700; }
    .watch-sector{ font-size:.72rem; color:var(--muted); }
    .watch-price-block { text-align:right; }
    .watch-price { font-size:1rem; font-weight:700; }
    .watch-pct   { font-size:.82rem; font-weight:700; }
    .score-bar-wrap { padding:.6rem 1rem .4rem; }
    .score-label { font-size:.7rem; color:var(--muted); margin-bottom:.3rem; display:flex; justify-content:space-between; }
    .score-bar { height:6px; border-radius:3px; background:rgba(255,255,255,.08); overflow:hidden; }
    .score-fill { height:100%; border-radius:3px; transition:width .8s ease; }
    .rating-badge {
      display:inline-block; padding:.25rem .7rem; border-radius:999px;
      font-size:.72rem; font-weight:700; margin-left:.5rem;
    }
    .r-強気    { background:rgba(0,255,163,.2);   color:var(--up);   border:1px solid rgba(0,255,163,.4);   }
    .r-やや強気 { background:rgba(0,255,163,.1);   color:var(--up);   border:1px solid rgba(0,255,163,.25);  }
    .r-中立    { background:rgba(170,170,204,.1); color:var(--flat); border:1px solid rgba(170,170,204,.25); }
    .r-やや弱気 { background:rgba(255,77,109,.1);  color:var(--down); border:1px solid rgba(255,77,109,.25); }
    .r-弱気    { background:rgba(255,77,109,.2);   color:var(--down); border:1px solid rgba(255,77,109,.4);  }
    .watch-body { padding:.75rem 1rem; }
    .watch-reason { font-size:.87rem; line-height:1.75; color:var(--text); margin-bottom:.6rem; }
    .watch-points { list-style:none; margin-bottom:.6rem; }
    .watch-points li { font-size:.82rem; color:#a5f3fc; padding:.2rem 0; display:flex; gap:.4rem; }
    .watch-points li::before { content:"▸"; color:var(--accent3); flex-shrink:0; }
    .watch-caution { font-size:.8rem; color:#fca5a5; padding:.5rem .75rem; background:rgba(255,77,109,.08); border-left:3px solid rgba(255,77,109,.4); border-radius:0 6px 6px 0; }
    .watch-entry { font-size:.8rem; color:#fde68a; margin-top:.6rem; padding:.5rem .75rem; background:rgba(251,191,36,.08); border-left:3px solid rgba(251,191,36,.4); border-radius:0 6px 6px 0; }

    /* ── 市場解説 ── */
    .commentary-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:.9rem; }
    .commentary-card { padding:1rem 1rem 1rem .9rem; border-radius:var(--radius); border-left:4px solid; background:var(--glass); transition:transform .2s; }
    .commentary-card:hover { transform:translateY(-3px); }
    .overview-card { border-color:#a78bfa; background:rgba(124,58,237,.1); }
    .drivers-card  { border-color:#f472b6; background:rgba(236,72,153,.08); }
    .trends-card   { border-color:#22d3ee; background:rgba(6,182,212,.08); }
    .commentary-icon { font-size:1.4rem; margin-bottom:.3rem; }
    .commentary-label { font-size:.68rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:var(--muted); margin-bottom:.4rem; }
    .commentary-text { font-size:.88rem; line-height:1.8; }

    /* ── 注目銘柄 ── */
    .featured-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:1rem; }
    .featured-card { border-radius:var(--radius); background:var(--glass); border:1px solid rgba(255,255,255,.1); overflow:hidden; transition:transform .2s, box-shadow .2s; }
    .featured-card:hover { transform:translateY(-5px); box-shadow:0 12px 40px rgba(0,0,0,.4); }
    .featured-card.risk-高 { border-top:3px solid #ff4d6d; }
    .featured-card.risk-中 { border-top:3px solid #fbbf24; }
    .featured-card.risk-低 { border-top:3px solid #00ffa3; }
    .featured-header { display:flex; align-items:center; gap:.65rem; padding:.85rem .85rem .65rem; background:rgba(255,255,255,.04); border-bottom:1px solid rgba(255,255,255,.07); }
    .featured-emoji { font-size:1.9rem; flex-shrink:0; }
    .featured-name  { font-size:.95rem; font-weight:700; margin-bottom:.3rem; }
    .featured-badges { display:flex; flex-wrap:wrap; gap:.25rem; }
    .type-badge { font-size:.62rem; font-weight:700; padding:.12rem .45rem; border-radius:999px; background:rgba(124,58,237,.3); border:1px solid rgba(167,139,250,.4); color:#c4b5fd; }
    .tag-badge  { font-size:.62rem; font-weight:700; padding:.12rem .45rem; border-radius:999px; background:rgba(6,182,212,.2); border:1px solid rgba(6,182,212,.35); color:#67e8f9; }
    .risk-badge { font-size:.62rem; font-weight:700; padding:.12rem .45rem; border-radius:999px; }
    .risk-badge.risk-高 { background:rgba(255,77,109,.2);  border:1px solid rgba(255,77,109,.4);  color:#ff4d6d; }
    .risk-badge.risk-中 { background:rgba(251,191,36,.15); border:1px solid rgba(251,191,36,.35); color:#fbbf24; }
    .risk-badge.risk-低 { background:rgba(0,255,163,.12);  border:1px solid rgba(0,255,163,.3);  color:#00ffa3; }
    .featured-section { padding:.65rem .85rem; border-bottom:1px solid rgba(255,255,255,.05); }
    .featured-section:last-child { border-bottom:none; }
    .featured-section-title { font-size:.68rem; font-weight:700; letter-spacing:.06em; color:var(--muted); margin-bottom:.3rem; }
    .featured-body { font-size:.84rem; line-height:1.75; }
    .featured-body.outlook { color:#a5f3fc; }

    /* ── AI バッジ ── */
    .ai-badge { font-size:.62rem; font-weight:700; padding:.18rem .55rem; background:linear-gradient(135deg,rgba(124,58,237,.4),rgba(236,72,153,.3)); border:1px solid rgba(167,139,250,.4); border-radius:999px; color:#c4b5fd; vertical-align:middle; margin-left:.4rem; }

    /* ── APIキー未設定通知 ── */
    .no-api-notice { display:flex; align-items:flex-start; gap:.85rem; padding:1rem 1.25rem; background:rgba(251,191,36,.06); border:1px dashed rgba(251,191,36,.35); border-radius:var(--radius); color:var(--muted); }
    .no-api-icon  { font-size:1.6rem; flex-shrink:0; }
    .no-api-title { font-weight:700; color:#fbbf24; margin-bottom:.25rem; }
    .no-api-body  { font-size:.85rem; line-height:1.65; }
    .no-api-body code { background:rgba(255,255,255,.1); padding:.1rem .35rem; border-radius:4px; font-family:monospace; color:#a78bfa; }

    /* ── フッター ── */
    footer { text-align:center; padding:1.5rem 1rem; font-size:.75rem; color:var(--muted); border-top:1px solid rgba(255,255,255,.07); margin-top:1.5rem; }
    footer a { color:var(--accent3); text-decoration:none; }

    [x-cloak] { display:none !important; }
    ::-webkit-scrollbar { width:5px; }
    ::-webkit-scrollbar-track { background:var(--bg0); }
    ::-webkit-scrollbar-thumb { background:rgba(167,139,250,.4); border-radius:3px; }
  </style>
</head>

<body>

<!-- ████  HEADER  ████ -->
<header>
  <div class="site-title">🌍 世界の株式市場ダッシュボード</div>
  <div class="update-badge">
    <span class="pulse-dot"></span>🕐 最終更新: {{ updated_at }}
  </div>
</header>

<!-- ████  市場タイマー  ████ -->
<div class="timer-bar" id="timerBar">
  <div class="timer-clock" id="clockDisplay">--:--:--</div>
  <div class="market-status">
    <span class="status-badge" id="statusBadge">読み込み中...</span>
    <span class="countdown" id="countdownDisplay"></span>
  </div>
</div>

<!-- ████  TICKER BAR  ████ -->
<div class="ticker-wrap">
  <div class="ticker-track">
    {% set all_tickers = prices.indices + prices.crypto + prices.commodities %}
    {% for item in all_tickers * 2 %}
    <span class="ticker-item {{ item.direction if item.price else 'flat' }}">
      {{ item.emoji }} {{ item.name }}
      {% if item.price %}
        {% if item.price >= 1000 %}${{ "{:,.0f}".format(item.price) }}
        {% elif item.price >= 1   %}${{ "{:.2f}".format(item.price) }}
        {% else                   %}${{ "{:.4f}".format(item.price) }}{% endif %}
        {{ item.arrow }}{{ "{:+.2f}".format(item.change_pct) }}%
      {% else %}―{% endif %}
    </span>
    {% endfor %}
  </div>
</div>

<!-- ████  寄り付き前チェック  ████ -->
<div class="section">
  <div class="section-title">🌅 寄り付き前チェック</div>
  <div class="premarket-grid">
    {% for pm in prices.premarket %}
    <div class="premarket-card">
      <div class="pm-emoji">{{ pm.emoji }}</div>
      <div class="pm-name">{{ pm.name }}</div>
      {% if pm.price %}
      <div class="pm-price {{ pm.direction }}">
        {% if pm.price >= 100 %}{{ "{:,.2f}".format(pm.price) }}
        {% else               %}{{ "{:.3f}".format(pm.price) }}{% endif %}
      </div>
      <div class="pm-pct {{ pm.direction }}">{{ pm.arrow }} {{ "{:+.2f}".format(pm.change_pct) }}%</div>
      {% else %}<div class="pm-price flat">―</div>{% endif %}
    </div>
    {% endfor %}
  </div>
</div>

<div class="divider"></div>

<!-- ████  主要指数（コンパクト）  ████ -->
<div class="section">
  <div class="section-title">📊 主要指数</div>
  <div class="compact-row">
    {% for idx in prices.indices %}
    <div class="compact-chip {{ idx.direction if idx.price else 'flat' }}">
      <span>{{ idx.emoji }}</span>
      <span class="chip-name">{{ idx.name }}</span>
      {% if idx.price %}
      <span class="chip-price">
        {% if idx.price >= 1000 %}{{ "{:,.0f}".format(idx.price) }}
        {% else                  %}{{ "{:.2f}".format(idx.price) }}{% endif %}
      </span>
      <span class="chip-pct">{{ idx.arrow }}{{ "{:+.2f}".format(idx.change_pct) }}%</span>
      {% else %}<span class="flat">―</span>{% endif %}
    </div>
    {% endfor %}
  </div>
</div>

<div class="divider"></div>

<!-- ████  仮想通貨 & コモディティ（コンパクト）  ████ -->
<div class="section">
  <div class="section-title">🪙 仮想通貨 &nbsp;|&nbsp; 🏅 コモディティ</div>
  <div class="compact-row">
    {% for c in prices.crypto %}
    <div class="compact-chip {{ c.direction if c.price else 'flat' }}">
      <span>{{ c.emoji }}</span>
      <span class="chip-name">{{ c.name }}</span>
      {% if c.price %}
      <span class="chip-price">
        {% if c.price >= 1000 %}${{ "{:,.0f}".format(c.price) }}
        {% else                %}${{ "{:.2f}".format(c.price) }}{% endif %}
      </span>
      <span class="chip-pct">{{ c.arrow }}{{ "{:+.2f}".format(c.change_pct) }}%</span>
      {% else %}<span class="flat">―</span>{% endif %}
    </div>
    {% endfor %}
    {% for m in prices.commodities %}
    <div class="compact-chip {{ m.direction if m.price else 'flat' }}">
      <span>{{ m.emoji }}</span>
      <span class="chip-name">{{ m.name }}</span>
      {% if m.price %}
      <span class="chip-price">
        {% if m.price >= 100 %}${{ "{:,.1f}".format(m.price) }}
        {% else               %}${{ "{:.2f}".format(m.price) }}{% endif %}
      </span>
      <span class="chip-pct">{{ m.arrow }}{{ "{:+.2f}".format(m.change_pct) }}%</span>
      {% else %}<span class="flat">―</span>{% endif %}
    </div>
    {% endfor %}
  </div>
</div>

<div class="divider"></div>

<!-- ████  セクター別動向  ████ -->
<div class="section">
  <div class="section-title">🏢 セクター別動向 (米国ETF)</div>
  <div class="sector-grid">
    {% for s in prices.sectors %}
    <span class="sector-pill {{ s.direction if s.price else 'flat' }}">
      {{ s.emoji }} {{ s.name }}
      {% if s.price %}{{ s.arrow }}{{ "{:+.2f}".format(s.change_pct) }}%{% else %}―{% endif %}
    </span>
    {% endfor %}
  </div>
</div>

<div class="divider"></div>

<!-- ████  為替感応度マップ  ████ -->
<div class="section">
  {% set usdjpy = prices.premarket | selectattr("ticker","equalto","JPY=X") | list %}
  {% set fx = usdjpy[0] if usdjpy else {} %}
  <div class="section-title">
    💱 為替感応度マップ
    {% if fx.price %}
    <span class="fx-indicator {{ fx.direction }}">
      {{ fx.emoji }} {{ "{:,.2f}".format(fx.price) }}円
      {{ fx.arrow }}{{ "{:+.2f}".format(fx.change_pct) }}%
    </span>
    {% endif %}
  </div>
  <div class="fx-map">
    <div class="fx-card weak-yen">
      <div class="fx-card-title">📉 円安メリット（輸出・グローバル）</div>
      <span class="fx-tag fx-up">🚗 自動車（トヨタ・ホンダ）</span>
      <span class="fx-tag fx-up">📱 電機・精密（ソニー・キヤノン）</span>
      <span class="fx-tag fx-up">⚙️ 機械（ファナック・コマツ）</span>
      <span class="fx-tag fx-up">🎮 ゲーム（任天堂）</span>
      <span class="fx-tag fx-up">💊 製薬（武田・中外）</span>
    </div>
    <div class="fx-card strong-yen">
      <div class="fx-card-title">📈 円高メリット（内需・輸入）</div>
      <span class="fx-tag fx-down">🛒 内需小売（ファストリ・イオン）</span>
      <span class="fx-tag fx-down">🏠 不動産・建設</span>
      <span class="fx-tag fx-down">🍜 食品・外食</span>
      <span class="fx-tag fx-down">✈️ 航空・旅行（JAL・ANA）</span>
      <span class="fx-tag fx-down">🔌 電力・ガス</span>
    </div>
  </div>
</div>

<div class="divider"></div>

<!-- ████  値上がり・値下がりランキング  ████ -->
<div class="section">
  <div class="section-title">📈 日本株 前日比ランキング</div>
  <div class="ranking-grid">
    <div class="ranking-list">
      <div class="ranking-header up-head">🚀 値上がりTOP5</div>
      <div class="ranking-body up-body">
        {% for s in prices.gainers %}
        <div class="ranking-row">
          <span class="rank-num">{{ loop.index }}</span>
          <span class="rank-name">{{ s.name }}</span>
          <span class="rank-pct up">▲ {{ "{:+.2f}".format(s.change_pct) }}%</span>
        </div>
        {% else %}
        <div class="ranking-row"><span style="color:var(--muted);font-size:.82rem;">データなし</span></div>
        {% endfor %}
      </div>
    </div>
    <div class="ranking-list">
      <div class="ranking-header down-head">💥 値下がりTOP5</div>
      <div class="ranking-body down-body">
        {% for s in prices.losers %}
        <div class="ranking-row">
          <span class="rank-num">{{ loop.index }}</span>
          <span class="rank-name">{{ s.name }}</span>
          <span class="rank-pct down">▼ {{ "{:.2f}".format(s.change_pct | abs) }}%</span>
        </div>
        {% else %}
        <div class="ranking-row"><span style="color:var(--muted);font-size:.82rem;">データなし</span></div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<div class="divider"></div>

<!-- ████  個人ウォッチリスト  ████ -->
<div class="section">
  <div class="section-title">👀 個人ウォッチリスト <span class="ai-badge">✨ AI評価</span></div>
  {% if watchlist_analysis %}
  <div class="watchlist-grid">
    {% for w in watchlist_analysis %}
    <div class="watch-card">
      <div class="watch-header">
        <span class="watch-emoji">{{ w.emoji }}</span>
        <div class="watch-info">
          <div class="watch-name">
            {{ w.name }}
            <span class="rating-badge r-{{ w.rating }}">{{ w.rating }}</span>
          </div>
          <div class="watch-sector">{{ w.get("sector","") if w.get("sector") else w.ticker }}</div>
        </div>
        <div class="watch-price-block">
          {% if w.price %}
          <div class="watch-price {{ w.direction }}">{{ "{:,.1f}".format(w.price) }}円</div>
          <div class="watch-pct {{ w.direction }}">{{ w.arrow }} {{ "{:+.2f}".format(w.change_pct) }}%</div>
          {% endif %}
        </div>
      </div>
      {% if w.score %}
      <div class="score-bar-wrap">
        <div class="score-label">
          <span>強気スコア</span>
          <span style="font-weight:700;color:var(--text)">{{ w.score }}/10</span>
        </div>
        <div class="score-bar">
          <div class="score-fill" style="width:{{ w.score * 10 }}%;background:{% if w.score >= 7 %}var(--up){% elif w.score >= 4 %}#fbbf24{% else %}var(--down){% endif %}"></div>
        </div>
      </div>
      {% endif %}
      <div class="watch-body">
        <div class="watch-reason">{{ w.reason }}</div>
        {% if w.points %}
        <ul class="watch-points">
          {% for pt in w.points %}<li>{{ pt }}</li>{% endfor %}
        </ul>
        {% endif %}
        {% if w.caution %}
        <div class="watch-caution">⚠️ {{ w.caution }}</div>
        {% endif %}
        {% if w.entry_hint %}
        <div class="watch-entry">💡 {{ w.entry_hint }}</div>
        {% endif %}
      </div>
    </div>
    {% endfor %}
  </div>
  {% else %}
  <div class="no-api-notice">
    <span class="no-api-icon">🔑</span>
    <div>
      <div class="no-api-title">AI評価を有効にするには</div>
      <div class="no-api-body"><code>ANTHROPIC_API_KEY</code> をGitHub Secretsに登録してください。</div>
    </div>
  </div>
  {% endif %}
</div>

<div class="divider"></div>

<!-- ████  市場解説  ████ -->
