      <div class="commentary-label">市場概況</div>
      <div class="commentary-text">{{ commentary.overview }}</div>
    </div>
    {% endif %}
    {% if commentary.drivers %}
    <div class="commentary-card drivers-card">
      <div class="commentary-icon">🔍</div>
      <div class="commentary-label">相場を動かした要因</div>
      <div class="commentary-text">{{ commentary.drivers }}</div>
    </div>
    {% endif %}
    {% if commentary.global_trends %}
    <div class="commentary-card trends-card">
      <div class="commentary-icon">🌐</div>
      <div class="commentary-label">グローバル動向</div>
      <div class="commentary-text">{{ commentary.global_trends }}</div>
    </div>
    {% endif %}
  </div>
  {% else %}
  <div class="no-api-notice">
    <span class="no-api-icon">🔑</span>
    <div>
      <div class="no-api-title">AI解説を有効にするには</div>
      <div class="no-api-body">GitHub Secrets に <code>ANTHROPIC_API_KEY</code> を登録後、ワークフローを再実行してください。</div>
    </div>
  </div>
  {% endif %}
</div>

<div class="divider"></div>

<!-- ████  注目銘柄特集  ████ -->
<div class="section">
  <div class="section-title">🔥 本日の注目銘柄・業界特集 <span class="ai-badge">✨ AI Picks</span></div>
  {% if featured %}
  <div class="featured-grid">
    {% for pick in featured %}
    <div class="featured-card risk-{{ pick.risk }}">
      <div class="featured-header">
        <span class="featured-emoji">{{ pick.emoji }}</span>
        <div>
          <div class="featured-name">{{ pick.name }}</div>
          <div class="featured-badges">
            <span class="type-badge">{{ pick.type }}</span>
            <span class="tag-badge">{{ pick.tag }}</span>
            <span class="risk-badge risk-{{ pick.risk }}">リスク {{ pick.risk }}</span>
          </div>
        </div>
      </div>
      <div class="featured-section">
        <div class="featured-section-title">💡 注目理由</div>
        <div class="featured-body">{{ pick.reason }}</div>
      </div>
      <div class="featured-section">
        <div class="featured-section-title">🔭 今後の見通し</div>
        <div class="featured-body outlook">{{ pick.outlook }}</div>
      </div>
    </div>
    {% endfor %}
  </div>
  {% else %}
  <div class="no-api-notice">
    <span class="no-api-icon">🔑</span>
    <div>
      <div class="no-api-title">AI注目銘柄を有効にするには</div>
      <div class="no-api-body">GitHub Secrets に <code>ANTHROPIC_API_KEY</code> を登録後、ワークフローを再実行してください。</div>
    </div>
  </div>
  {% endif %}
</div>

