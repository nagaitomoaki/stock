<!-- ████  市場タイマー JS  ████ -->
<script>
(function() {
  const SESSIONS = [
    { name: "前場",   start: [9,0],  end: [11,30], cls: "status-open",   icon: "🟢" },
    { name: "昼休み", start: [11,30],end: [12,30], cls: "status-lunch",  icon: "🍱" },
    { name: "後場",   start: [12,30],end: [15,30], cls: "status-open",   icon: "🟢" },
  ];

  function toMinutes(h, m) { return h * 60 + m; }

  function update() {
    const now = new Date();
    const jst = new Date(now.toLocaleString("en-US", { timeZone: "Asia/Tokyo" }));
    const h = jst.getHours(), m = jst.getMinutes(), s = jst.getSeconds();
    const cur = toMinutes(h, m);
    const pad = n => String(n).padStart(2, "0");

    document.getElementById("clockDisplay").textContent =
      `${pad(h)}:${pad(m)}:${pad(s)} JST`;

    let badge = document.getElementById("statusBadge");
    let countdown = document.getElementById("countdownDisplay");
    let found = false;

    for (const ses of SESSIONS) {
      const st = toMinutes(...ses.start), en = toMinutes(...ses.end);
      if (cur >= st && cur < en) {
        badge.className = "status-badge " + ses.cls;
        badge.textContent = ses.icon + " " + ses.name + " 取引中";
        const rem = en - cur - 1;
        const remH = Math.floor(rem / 60), remM = rem % 60;
        countdown.textContent = `終了まで ${remH > 0 ? remH + "時間" : ""}${remM}分`;
        found = true; break;
      }
    }
    if (!found) {
      // 次のセッションを探す
      let next = null;
      for (const ses of SESSIONS) {
        const st = toMinutes(...ses.start);
        if (st > cur) { next = ses; break; }
      }
      if (next) {
        badge.className = "status-badge status-pre";
        badge.textContent = "⏳ 次: " + next.name;
        const diff = toMinutes(...next.start) - cur;
        const dH = Math.floor(diff / 60), dM = diff % 60;
        countdown.textContent = `開始まで ${dH > 0 ? dH + "時間" : ""}${dM}分`;
      } else {
        badge.className = "status-badge status-closed";
        badge.textContent = "🔴 クローズ";
        countdown.textContent = "次回: 翌営業日 09:00 JST";
      }
    }
  }

  update();
  setInterval(update, 1000);
})();
</script>

</body>
</html>
